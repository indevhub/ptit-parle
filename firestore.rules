
// VERSION: 2026-05-15T12:30:00Z - FORCING RE-DEPLOYMENT
// PLEASE MANUALLY COPY THIS INTO THE FIREBASE CONSOLE IF YOU SEE PERMISSION ERRORS.
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function
    function isSignedIn() {
      return request.auth != null;
    }
    
    // Allow any authenticated user to manage their own family tree and all data within it
    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
      
      match /{allSubcollections=**} {
        allow read, write: if isSignedIn() && request.auth.uid == userId;
      }
    }

    // Global reference data is read-only for all explorers
    match /lessons/{lessonId} {
      allow read: if true;
      allow write: if false;
    }

    match /achievements/{id} {
      allow read: if true;
      allow write: if false;
    }
  }
}
