
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    match /users/{userId}/learnerProfiles/{learnerProfileId} {
      allow read, write: if isOwner(userId);
      
      match /phrases/{phraseId} {
        allow read, write: if isOwner(userId);
      }
      
      match /lessonProgresses/{lessonId} {
        allow read, write: if isOwner(userId);
      }
      
      match /vocabularyProgresses/{vocabId} {
        allow read, write: if isOwner(userId);
      }
    }

    match /lessons/{lessonId} {
      allow read: if true;
      allow write: if false;
      
      match /vocabularyItems/{vocabId} {
        allow read: if true;
        allow write: if false;
      }
    }

    match /achievements/{id} {
      allow read: if true;
      allow write: if false;
    }
    
    match /roles_admin/{id} {
      allow read: if isSignedIn();
      allow write: if false;
    }
  }
}
