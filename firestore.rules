
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function for general authentication check
    function isSignedIn() {
      return request.auth != null;
    }
    
    // Explicit rules for family accounts and their sub-data
    match /users/{userId} {
      // Allow a user full access (read/write) to their own root document and all nested data
      allow read, write: if isSignedIn() && request.auth.uid == userId;
      
      // Recursive match for all learner profiles, magic phrases, etc.
      match /{allSubcollections=**} {
        allow read, write: if isSignedIn() && request.auth.uid == userId;
      }
    }

    // Lessons and vocabulary reference data (Read-Only for everyone)
    match /lessons/{lessonId} {
      allow read: if true;
      allow write: if false;
      
      match /{allSubcollections=**} {
        allow read: if true;
        allow write: if false;
      }
    }

    // Achievement reference data (Read-Only for everyone)
    match /achievements/{id} {
      allow read: if true;
      allow write: if false;
    }
  }
}
