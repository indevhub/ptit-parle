rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions for security rules
    function isSignedIn() {
      return request.auth != null;
    }
    
    // Updated: 2024-05-20
    // Rules for the users collection
    match /users/{userId} {
      // Explicitly allow the owner to manage their family account document
      allow get, list, create, update, delete: if isSignedIn() && request.auth.uid == userId;
      
      // Rules for learner profiles within a family account
      match /learnerProfiles/{learnerProfileId} {
        allow read, write: if isSignedIn() && request.auth.uid == userId;
        
        // Rules for phrases created by a specific learner
        match /phrases/{phraseId} {
          allow read, write: if isSignedIn() && request.auth.uid == userId;
        }
        
        // Rules for tracking lesson progress
        match /lessonProgresses/{lessonId} {
          allow read, write: if isSignedIn() && request.auth.uid == userId;
        }
        
        // Rules for tracking vocabulary mastery
        match /vocabularyProgresses/{vocabId} {
          allow read, write: if isSignedIn() && request.auth.uid == userId;
        }
      }
    }

    // Global lessons are readable by everyone
    match /lessons/{lessonId} {
      allow read: if true;
      allow write: if false;
      
      match /vocabularyItems/{vocabId} {
        allow read: if true;
        allow write: if false;
      }
    }

    // Achievements reference data
    match /achievements/{id} {
      allow read: if true;
      allow write: if false;
    }
  }
}