
// VERSION: 2026-04-20T06:15:00Z - FORCING RE-DEPLOYMENT TO RESOLVE PERMISSION ERRORS
// IF YOU SEE PERMISSION ERRORS, MANUALLY COPY THIS ENTIRE FILE INTO THE FIREBASE CONSOLE.
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function for general authentication check
    function isSignedIn() {
      return request.auth != null;
    }
    
    // Explicit rules for family accounts and their sub-data
    match /users/{userId} {
      // Allow a family full access to their own account document and all nested data
      allow read, write: if isSignedIn() && request.auth.uid == userId;
      
      match /{allSubcollections=**} {
        allow read, write: if isSignedIn() && request.auth.uid == userId;
      }
    }

    // Reference data (Lessons, achievements, etc.) is Read-Only for everyone
    match /lessons/{lessonId} {
      allow read: if true;
      allow write: if false;
      match /{allSubcollections=**} {
        allow read: if true;
        allow write: if false;
      }
    }

    match /achievements/{id} {
      allow read: if true;
      allow write: if false;
    }
  }
}
