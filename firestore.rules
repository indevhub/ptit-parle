
// LAST UPDATED: 2026-04-20T04:35:00Z - FORCING RE-DEPLOYMENT FOR PERMISSIONS
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function for general authentication check
    function isSignedIn() {
      return request.auth != null;
    }
    
    // Explicit rules for family accounts and their sub-data
    match /users/{userId} {
      // Allow a family full access to their own account document
      // Using 'write' as a robust catch-all for create/update/delete
      allow read, write: if isSignedIn() && request.auth.uid == userId;
      
      // Allow a family full access to all nested learner profiles, custom images, etc.
      match /{allSubcollections=**} {
        allow read, write: if isSignedIn() && request.auth.uid == userId;
      }
    }

    // Lessons and vocabulary reference data (Read-Only for everyone)
    match /lessons/{lessonId} {
      allow read: if true;
      allow write: if false;
      
      match /{allSubcollections=**} {
        allow read: if true;
        allow write: if false;
      }
    }

    // Achievement reference data (Read-Only for everyone)
    match /achievements/{id} {
      allow read: if true;
      allow write: if false;
    }
  }
}
