
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function for general authentication check
    function isSignedIn() {
      return request.auth != null;
    }
    
    // Updated: Explicit rules for account management
    match /users/{userId} {
      // Allow a user full access to their own data
      allow read, write: if isSignedIn() && request.auth.uid == userId;
      
      // Explicit recursive rules for all subcollections
      match /{allSubcollections=**} {
        allow read, write: if isSignedIn() && request.auth.uid == userId;
      }
    }

    // Lessons and vocabulary reference data (Read-Only)
    match /lessons/{lessonId} {
      allow read: if true;
      allow write: if false;
      
      match /{allSubcollections=**} {
        allow read: if true;
        allow write: if false;
      }
    }

    // Achievement reference data (Read-Only)
    match /achievements/{id} {
      allow read: if true;
      allow write: if false;
    }
  }
}
