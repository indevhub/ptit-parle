
{
  "entities": {
    "LearnerProfile": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "LearnerProfile",
      "type": "object",
      "description": "Represents an individual child learner's profile and overall progress in the P'tit Parlé application.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the LearnerProfile entity."
        },
        "name": {
          "type": "string",
          "description": "The display name of the child learner."
        },
        "avatarUrl": {
          "type": "string",
          "description": "URL to the child's chosen avatar image.",
          "format": "uri"
        },
        "totalStarsEarned": {
          "type": "number",
          "description": "The total number of stars earned by the learner across all activities."
        },
        "currentTheme": {
          "type": "string",
          "description": "The current UI theme preference for the learner (e.g., 'Default', 'Pink')."
        },
        "lastActiveAt": {
          "type": "string",
          "description": "Timestamp of the learner's last activity in the application.",
          "format": "date-time"
        }
      },
      "required": [
        "id",
        "name",
        "totalStarsEarned",
        "currentTheme",
        "lastActiveAt"
      ]
    },
    "PhraseItem": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "PhraseItem",
      "type": "object",
      "description": "A custom phrase translated from English to French by the learner.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier."
        },
        "frenchText": {
          "type": "string",
          "description": "The translated French phrase."
        },
        "englishText": {
          "type": "string",
          "description": "The original English phrase."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "isMastered": {
          "type": "boolean"
        }
      },
      "required": ["id", "frenchText", "englishText", "createdAt"]
    },
    "Lesson": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Lesson",
      "type": "object",
      "description": "Represents a structured collection of French vocabulary and phrases, designed as a learning unit.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the Lesson entity."
        },
        "name": {
          "type": "string",
          "description": "The title or name of the lesson (e.g., 'Animals', 'Greetings')."
        },
        "description": {
          "type": "string",
          "description": "A brief description of the content covered in the lesson."
        },
        "orderIndex": {
          "type": "number",
          "description": "The numerical order in which the lesson should be presented in the application."
        },
        "thumbnailUrl": {
          "type": "string",
          "description": "URL to an image representing the lesson for display purposes.",
          "format": "uri"
        }
      },
      "required": [
        "id",
        "name",
        "description",
        "orderIndex",
        "thumbnailUrl"
      ]
    },
    "VocabularyItem": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "VocabularyItem",
      "type": "object",
      "description": "Represents a single French word or phrase with its associated learning materials.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the VocabularyItem entity."
        },
        "lessonId": {
          "type": "string",
          "description": "Reference to the Lesson this vocabulary item belongs to."
        },
        "frenchText": {
          "type": "string",
          "description": "The French word or phrase."
        },
        "englishTranslation": {
          "type": "string",
          "description": "The English translation of the French word or phrase."
        },
        "audioUrl": {
          "type": "string",
          "description": "URL to the audio recording.",
          "format": "uri"
        },
        "imageUrl": {
          "type": "string",
          "description": "URL to a visual aid image.",
          "format": "uri"
        },
        "difficultyLevel": {
          "type": "string",
          "description": "Indicator of difficulty."
        }
      },
      "required": [
        "id",
        "lessonId",
        "frenchText",
        "englishTranslation",
        "audioUrl",
        "imageUrl",
        "difficultyLevel"
      ]
    },
    "LearnerLessonProgress": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "LearnerLessonProgress",
      "type": "object",
      "description": "Tracks progress in a lesson.",
      "properties": {
        "id": { "type": "string" },
        "learnerId": { "type": "string" },
        "lessonId": { "type": "string" },
        "status": { "type": "string" },
        "starsEarned": { "type": "number" },
        "lastAccessedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "learnerId", "lessonId", "status", "starsEarned", "lastAccessedAt"]
    }
  },
  "auth": {
    "providers": [
      "password",
      "anonymous"
    ]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}/learnerProfiles/{learnerProfileId}",
        "definition": {
          "entityName": "LearnerProfile",
          "schema": { "$ref": "#/backend/entities/LearnerProfile" },
          "description": "Root profile for a learner."
        }
      },
      {
        "path": "/users/{userId}/learnerProfiles/{learnerProfileId}/phrases/{phraseId}",
        "definition": {
          "entityName": "PhraseItem",
          "schema": { "$ref": "#/backend/entities/PhraseItem" },
          "description": "Custom phrases created by the learner via English-to-French translation."
        }
      },
      {
        "path": "/lessons/{lessonId}",
        "definition": {
          "entityName": "Lesson",
          "schema": { "$ref": "#/backend/entities/Lesson" },
          "description": "Global lessons."
        }
      }
    ]
  }
}
